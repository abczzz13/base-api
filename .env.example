VERSION=dev
GIT_COMMIT=unknown
GIT_BRANCH=unknown
GIT_TAG=unknown
GIT_TREE_STATE=unknown
BUILD_TIME=unknown

# Runtime config keys also support a companion <KEY>_FILE variable.
# Example: LOG_LEVEL_FILE=/run/secrets/log_level
API_ADDR=0.0.0.0:8080
# API_PORT is used by compose port mapping only.
API_PORT=8080
API_INFRA_ADDR=127.0.0.1:9090
API_ENVIRONMENT=development
LOG_FORMAT=text
LOG_LEVEL=info

# DB_URL is required when running the API directly on the host.
# Compose derives container DB_URL from POSTGRES_* settings below.
DB_URL=postgres://postgres:postgres@127.0.0.1:5432/base_api?sslmode=disable
DB_MIN_CONNS=0
DB_MAX_CONNS=20
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
# When non-empty, DB_CONNECT_TIMEOUT overrides connect_timeout in DB_URL.
# Set DB_CONNECT_TIMEOUT=0s to keep connect_timeout from DB_URL.
DB_CONNECT_TIMEOUT=5s
DB_MIGRATE_ON_STARTUP=true
DB_MIGRATE_TIMEOUT=5m
# Database startup retries for transient open/migration failures.
DB_STARTUP_MAX_ATTEMPTS=5
DB_STARTUP_BACKOFF_INITIAL=1s
DB_STARTUP_BACKOFF_MAX=30s

# Local compose PostgreSQL settings (also used to construct container DB_URL).
POSTGRES_DB=base_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# OpenTelemetry tracing auto-enables when an OTLP endpoint is configured.
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SDK_DISABLED=false
# OTEL_TRACES_SAMPLER supports always_on, always_off, traceidratio,
# parentbased_always_on, parentbased_always_off, parentbased_traceidratio.
OTEL_TRACES_SAMPLER=parentbased_always_on
# Only used for traceidratio and parentbased_traceidratio samplers.
OTEL_TRACES_SAMPLER_ARG=

# CORS is deny-by-default unless origins are explicitly configured.
API_CORS_ALLOWED_ORIGINS=
API_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
API_CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept
API_CORS_EXPOSED_HEADERS=
API_CORS_ALLOW_CREDENTIALS=false
API_CORS_MAX_AGE=5m

# CSRF is enabled by default. If you allow browser cross-origin requests,
# set API_CSRF_TRUSTED_ORIGINS to the origins that may send unsafe methods.
API_CSRF_ENABLED=true
API_CSRF_TRUSTED_ORIGINS=

# Enable structured request logs for public, infra, and /metrics handlers.
API_REQUEST_LOGGER_ENABLED=true

# Supported modes: standalone, cluster
API_VALKEY_MODE=standalone
API_VALKEY_ADDRS=127.0.0.1:6379
# VALKEY_PORT is used by compose port mapping only.
VALKEY_PORT=6379

# Distributed public API rate limiting backed by Valkey.
# When running the API directly on the host, point this at your reachable Valkey.
# Compose derives the container-internal Valkey address from the local service below.
API_RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_FAIL_OPEN=true
API_RATE_LIMIT_TIMEOUT=100ms
API_RATE_LIMIT_DEFAULT_RPS=5
API_RATE_LIMIT_DEFAULT_BURST=10
API_RATE_LIMIT_KEY_PREFIX=base-api:ratelimit
# Example: {"getCurrentWeather":{"requestsPerSecond":2.5,"burst":4},"getHealthz":{"disabled":true}}
API_RATE_LIMIT_ROUTE_OVERRIDES_JSON=

# Open-Meteo example outbound integration.
# Set WEATHER_ENABLED=true to expose the example endpoint.
# Defaults point at the public Open-Meteo APIs.
WEATHER_ENABLED=false
WEATHER_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
WEATHER_FORECAST_BASE_URL=https://api.open-meteo.com
# Optional: only needed for commercial customer endpoints.
WEATHER_API_KEY=
WEATHER_TIMEOUT=5s

# Enable request audit persistence for public API requests.
API_REQUEST_AUDIT_ENABLED=true

# Comma-separated trusted proxy CIDRs used for shared client IP extraction.
# This affects both request audit and public API rate limiting.
# When empty, defaults to local/private proxy ranges.
API_TRUSTED_PROXY_CIDRS=

# API_READYZ_TIMEOUT is a single budget shared across all readiness checks.
API_READYZ_TIMEOUT=2s
API_READ_HEADER_TIMEOUT=5s
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=30s
API_IDLE_TIMEOUT=60s
