VERSION=dev
GIT_COMMIT=unknown
GIT_BRANCH=unknown
GIT_TAG=unknown
GIT_TREE_STATE=unknown
BUILD_TIME=unknown

API_PORT=8080
API_INFRA_ADDR=127.0.0.1:9090
API_ENVIRONMENT=development
LOG_FORMAT=text
LOG_LEVEL=info

# OpenTelemetry tracing auto-enables when an OTLP endpoint is configured.
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SDK_DISABLED=false
# OTEL_TRACES_SAMPLER supports always_on, always_off, traceidratio,
# parentbased_always_on, parentbased_always_off, parentbased_traceidratio.
OTEL_TRACES_SAMPLER=parentbased_always_on
# Only used for traceidratio and parentbased_traceidratio samplers.
OTEL_TRACES_SAMPLER_ARG=

# CORS is deny-by-default unless origins are explicitly configured.
API_CORS_ALLOWED_ORIGINS=
API_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
API_CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept
API_CORS_EXPOSED_HEADERS=
API_CORS_ALLOW_CREDENTIALS=false
API_CORS_MAX_AGE=5m

# CSRF is enabled by default. If you allow browser cross-origin requests,
# set API_CSRF_TRUSTED_ORIGINS to the origins that may send unsafe methods.
API_CSRF_ENABLED=true
API_CSRF_TRUSTED_ORIGINS=

API_READYZ_TIMEOUT=2s
API_READ_HEADER_TIMEOUT=5s
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=30s
API_IDLE_TIMEOUT=60s
